# Server
PORT=3000

# SQLite database file (relative to project root)
DATABASE_PATH=data/clinic.db

# Admin API protection — required header: x-admin-token
ADMIN_TOKEN=change-me

# Optional AI assistance. Leave the active provider's API key empty to run
# fully deterministic. Select provider: openrouter (default) | agentrouter
AI_PROVIDER=openrouter

# OpenRouter (used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AgentRouter (used when AI_PROVIDER=agentrouter) — https://docs.agentrouter.org/
# OpenAI-compatible; token from https://agentrouter.org/console/token
AGENTROUTER_API_KEY=
AGENTROUTER_MODEL=claude-opus-4-8
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
