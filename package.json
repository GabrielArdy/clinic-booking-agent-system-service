{
  "name": "clinic-booking-agent-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Conversational clinic appointment booking backend (SPEC-1)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "setup": "npm run migrate && npm run seed",
    "db:truncate": "tsx src/db/truncate.ts",
    "db:reset": "tsx src/db/truncate.ts --yes --seed",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ioredis": "^5.11.1",
    "pg": "^8.13.1",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
